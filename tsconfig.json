{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node", "@playwright/test"],
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "common/*": ["./helpers/common/*"],
      "config/*": ["./config/*"],
      "helpers/*": ["./helpers/*"],
      "utils/*": ["./utils/*"],
      "types/*": ["./types/*"]
    }
  }
}
