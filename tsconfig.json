{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["node", "@playwright/test"],
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "./",
    "baseUrl": ".",
    "paths": {
      "config/*": ["./config/*"],
      "framework/*": ["./framework/*"],
      "api/*": ["./helpers/api/*"],
      "common/*": ["./helpers/common/*"],
      "ui/*": ["./helpers/ui/*"],
      "locales/*": ["./locales/*"],
      "pages/*": ["./pages/*"],
      "constants/*": ["./shared/constants/*"],
      "types/*": ["./shared/types/*"],
      "utils/*": ["./shared/utils/*"]
    }
  },
  "include": ["@types/**/*.d.ts", "src", "tests", "helpers"]
}
